# ──────────────────────────────────────────────
# Immich PostgreSQL 데이터베이스 설정
# ──────────────────────────────────────────────
DB_HOSTNAME=immich_postgres
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here
DB_DATABASE_NAME=immich

# ──────────────────────────────────────────────
# Naver Cloud Platform API (한국 역지오코딩)
# https://www.ncloud.com/ 에서 발급
# ──────────────────────────────────────────────
NAVER_CLIENT_ID=your_client_id_here
NAVER_CLIENT_SECRET=your_client_secret_here
NAVER_API_TIMEOUT_MS=10000

# ──────────────────────────────────────────────
# Google Maps Geocoding API (한국 외 지역, 선택)
# https://console.cloud.google.com/ 에서 발급
# GEOCODING_WORLD=google 로 설정한 경우 필요
# ──────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_API_TIMEOUT_MS=10000

# ──────────────────────────────────────────────
# 지오코딩 제공자 설정
#   GEOCODING_KOREA: naver (기본) | google | disabled
#   GEOCODING_WORLD: disabled (기본) | google
# ──────────────────────────────────────────────
GEOCODING_KOREA=naver
GEOCODING_WORLD=disabled

# ──────────────────────────────────────────────
# 스케줄 설정
# CRON_SCHEDULE: cron 표현식 (기본: 매일 새벽 2시)
#   예) 0 2 * * *    → 매일 새벽 2시
#       0 */6 * * *  → 6시간마다
#       0 * * * *    → 매 시간
# RUN_ON_STARTUP: 시작 시 즉시 실행 여부 (기본: true)
# ──────────────────────────────────────────────
CRON_SCHEDULE=0 2 * * *
RUN_ON_STARTUP=true

# ──────────────────────────────────────────────
# 웹 관리 UI 설정
# WEB_PORT: 포트 번호 (기본: 3000)
# WEB_PASSWORD: Bearer 토큰 인증 (비워두면 인증 없음)
# ──────────────────────────────────────────────
WEB_PORT=3000
WEB_PASSWORD=

# ──────────────────────────────────────────────
# 성능 / 캐시 설정
# STEP_DELAY_MS: API 호출 간격 (밀리초, 기본: 100)
# CACHE_TTL_DAYS: 캐시 유효 기간 (일, 기본: 180)
# ──────────────────────────────────────────────
STEP_DELAY_MS=100
CACHE_TTL_DAYS=180
